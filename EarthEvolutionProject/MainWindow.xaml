<Window x:Class="EarthEvolutionProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EarthEvolutionProject"
        xmlns:views="clr-namespace:EarthEvolutionProject.Views"
        mc:Ignorable="d"
        Title="Розвиток життя на Землі" Height="700" Width="1100"
        Icon="/Images/Icon/earthicon.ico"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,2">
            <DockPanel Margin="20,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" 
                           Text="РОЗВИТОК ЖИТТЯ НА ЗЕМЛІ" 
                           Foreground="White"
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"/>

                <Button x:Name="ThemeButton" 
                        DockPanel.Dock="Right"
                        Width="35" Height="35" 
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        Click="ThemeButton_Click"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ThemeBorder" 
                                    Background="{DynamicResource SecondaryBackgroundBrush}" 
                                    CornerRadius="17.5" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1">
                                <TextBlock x:Name="ThemeIcon" 
                                           Text="🌙" 
                                           Foreground="{DynamicResource PrimaryTextBrush}" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="SettingsButton" 
                        DockPanel.Dock="Right"
                        Width="35" Height="35" 
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        Click="SettingsButton_Click"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SettingsBorder" 
                                    Background="{DynamicResource SecondaryBackgroundBrush}" 
                                    CornerRadius="17.5" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1">
                                <TextBlock Text="⚙️" 
                                           Foreground="{DynamicResource PrimaryTextBrush}" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SettingsBorder" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Popup x:Name="SettingsPopup"
                       PlacementTarget="{Binding ElementName=SettingsButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       Closed="SettingsPopup_Closed">

                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1.5" 
                            CornerRadius="10" 
                            Padding="15" 
                            Width="280"
                            Margin="0,5,0,0">

                        <StackPanel>
                            <TextBlock Text="Налаштування" 
                                       Foreground="{DynamicResource PrimaryTextBrush}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,10"/>

                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

                            <CheckBox x:Name="WelcomeFactsCheckBox" 
                                      Content="Показувати цікаві факти при запуску" 
                                      Foreground="{DynamicResource PrimaryTextBrush}" 
                                      FontSize="12"
                                      Cursor="Hand"
                                      Checked="WelcomeFactsCheckBox_Changed"
                                      Unchecked="WelcomeFactsCheckBox_Changed">
                                <CheckBox.Resources>
                                    <Style TargetType="BulletDecorator">
                                        <Setter Property="Margin" Value="0,0,6,0"/>
                                    </Style>
                                </CheckBox.Resources>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button x:Name="CompareButton" 
                    DockPanel.Dock="Right" 
                    Content="📊 Порівняти" 
                    Margin="10,0,10,0" 
                    Cursor="Hand" 
                    Click="CompareButton_Click" 
                    VerticalAlignment="Center" 
                    Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                Background="Transparent" 
                                BorderBrush="White" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="10,5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <views:SearchBarView x:Name="MainSearchBar" 
                                     DockPanel.Dock="Right"
                                     VerticalAlignment="Center"
                                     FilterChanged="MainSearchBar_FilterChanged" />
            </DockPanel>
        </Border>

        <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="20" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <views:PeriodDetailsView x:Name="PeriodDetails" Grid.Column="0" Margin="0,0,20,0"/>
            <views:SpeciesGalleryView x:Name="SpeciesControl" Grid.Column="1"/>
        </Grid>

        <Grid x:Name="SearchResultsGrid" 
              Grid.Row="1" 
              Visibility="Collapsed" 
              Background="{DynamicResource PrimaryBackgroundBrush}">
            <views:SearchResultsView x:Name="SearchResultsPage" 
                                     AnimalSelected="OnSearchResultSelected"/>
        </Grid>

        <Grid x:Name="ComparisonGrid" 
              Grid.Row="1" 
              Visibility="Collapsed" 
              Background="{DynamicResource PrimaryBackgroundBrush}">
            <views:ComparisonView x:Name="ComparisonPage"/>
        </Grid>

        <Border x:Name="TimelinePanel" Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,2,0,0">
            <Grid Margin="15,12,15,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#3E1F52" Margin="1,0" CornerRadius="2">
                        <TextBlock Text="МЕЗОЗОЙ"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" Background="#1B3A57" Margin="1,0" CornerRadius="2">
                        <TextBlock Text="КАЙНОЗОЙ"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <views:PeriodsTimelineView x:Name="TimelineControl"
                                           Grid.Row="2"
                                           PeriodSelected="OnTimelinePeriodSelected"/>
            </Grid>
        </Border>
    </Grid>
</Window>
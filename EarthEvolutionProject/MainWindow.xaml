<Window x:Class="EarthEvolutionProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EarthEvolutionProject"
        xmlns:views="clr-namespace:EarthEvolutionProject.Views"
        mc:Ignorable="d"
        Title="Розвиток життя на Землі" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#252525">
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0a3261" BorderBrush="#333" BorderThickness="0,0,0,2">
            <DockPanel Margin="20,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" 
                   Text="РОЗВИТОК ЖИТТЯ НА ЗЕМЛІ" 
                   Foreground="#FFFFFF" 
                   FontSize="22" 
                   FontWeight="SemiBold" 
                   VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center">
                    <TextBox Width="200" 
                     Height="30" 
                     Text="Пошук..." 
                     Background="#333" 
                     Foreground="Gray" 
                     Margin="0,0,10,0" 
                     Padding="10,0" 
                     VerticalContentAlignment="Center"/>
                    <Button Content="Фільтри" 
                    Width="90" 
                    Height="30" 
                    Background="Transparent" 
                    Foreground="White" 
                    BorderThickness="0" 
                    BorderBrush="Transparent"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <views:PeriodDetailsView Grid.Column="0" Margin="0,0,20,0"/>
            <views:SpeciesGalleryView x:Name="SpeciesControl" Grid.Column="1"/>
        </Grid>

        <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,2,0,0">
            <Grid Margin="15,12,15,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#3E1F52" Margin="1,0" CornerRadius="2">
                        <TextBlock Text="МЕЗОЗОЙ"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" Background="#1B3A57" Margin="1,0" CornerRadius="2">
                        <TextBlock Text="КАЙНОЗОЙ"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <views:PeriodsTimelineView x:Name="TimelineControl"
                                   Grid.Row="2"
                                   PeriodSelected="OnTimelinePeriodSelected"/>
            </Grid>
        </Border>
    </Grid>
</Window>
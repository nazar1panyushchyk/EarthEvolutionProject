<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#1a4a82"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#3a7bc8"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#222222"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#545454"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#E3F2FD"/>
</ResourceDictionary>
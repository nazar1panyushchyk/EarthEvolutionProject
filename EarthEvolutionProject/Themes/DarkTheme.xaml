<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#252525"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#0a3261"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#64B5F6"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#2D2D2D"/>
</ResourceDictionary>
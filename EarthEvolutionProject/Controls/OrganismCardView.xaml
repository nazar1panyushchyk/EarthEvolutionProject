<UserControl x:Class="EarthEvolutionProject.Controls.OrganismCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

    <Border Background="{DynamicResource PrimaryBackgroundBrush}" CornerRadius="8" Margin="4" Padding="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="0" 
                   Source="{Binding Image}" 
                   Stretch="Uniform" 
                   MaxHeight="120" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="1" Margin="0,5,0,0">
                <TextBlock Text="{Binding CommonName}" 
                           Foreground="{DynamicResource PrimaryTextBrush}" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           TextAlignment="Center" 
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding Type}" 
                           Foreground="{DynamicResource AccentBlueBrush}" 
                           FontSize="10" 
                           TextAlignment="Center" 
                           Margin="0,1,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
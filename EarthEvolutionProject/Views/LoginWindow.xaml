<Window x:Class="EarthEvolutionProject.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вибір акаунта" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackgroundBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock Text="ХТО ВИКОРИСТОВУЄ ДОДАТОК?" 
                       Foreground="{DynamicResource AccentBlueBrush}" 
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Оберіть існуючий профіль або створіть новий" 
                       Foreground="{DynamicResource SecondaryTextBrush}" 
                       FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SecondaryBackgroundBrush}" Padding="5">
            <Grid>
                <ListBox x:Name="UsersListBox" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         HorizontalContentAlignment="Stretch"
                         SelectionChanged="UsersListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="2" CornerRadius="5" Background="{DynamicResource HoverBackgroundBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                              Fill="{DynamicResource AccentBlueBrush}" 
                                              Width="20" Height="20" Stretch="Fill" Margin="0,0,15,0"/>
                                        <TextBlock Text="{Binding}" 
                                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                                   FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                        Width="28" Height="28"
                                        ToolTip="Видалити цей профіль"
                                        Cursor="Hand"
                                        Click="DeleteProfileItemButton_Click"
                                        CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4">
                                                    <TextBlock Text="🗑️" 
                                                        FontSize="14"
                                                        HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#44FF0000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="NoProfilesText" 
                           Text="Немає створених профілів" 
                           Foreground="{DynamicResource SecondaryTextBrush}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Visibility="Collapsed" FontStyle="Italic"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Або введіть ім'я для нового профілю:" 
                       Foreground="{DynamicResource PrimaryTextBrush}" 
                       FontSize="12" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NewUserTextBox" 
                         Height="35" 
                         VerticalContentAlignment="Center" 
                         Padding="10,0"
                         FontSize="14"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TextChanged="NewUserTextBox_TextChanged"/>

                <Button x:Name="LoginButton" 
                        Grid.Column="1" 
                        Content="Увійти" 
                        Width="100" Margin="10,0,0,0"
                        Background="{DynamicResource PrimaryBlueBrush}" 
                        Foreground="White"
                        FontWeight="Bold"
                        Click="LoginButton_Click" IsDefault="True"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
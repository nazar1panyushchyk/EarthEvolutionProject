<Window x:Class="EarthEvolutionProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EarthEvolutionProject"
        mc:Ignorable="d"
        Title="Розвиток життя на Землі" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    
    <Grid Background="#252525">
    <Grid.RowDefinitions>
        <RowDefinition Height="65"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="130"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,0,2">
        <DockPanel Margin="20,0">
            <TextBlock Text="РОЗВИТОК ЖИТТЯ НА ЗЕМЛІ" 
                   Foreground="#00D4FF" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <TextBox Width="200" Height="30" VerticalContentAlignment="Center" 
                     Text="Пошук виду..." Foreground="Gray" Margin="0,0,10,0"/>
                <Button Content="Фільтри" Width="90" Height="30" Background="#333" Foreground="White"/>
            </StackPanel>
        </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="15" Padding="25" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Юрський період" Foreground="White" FontSize="38" FontWeight="ExtraBold"/>
                    <TextBlock Text="201 – 145 млн років тому" Foreground="#00D4FF" FontSize="18" Margin="0,5,0,25" Opacity="0.8"/>

                    <Border CornerRadius="12" ClipToBounds="True" Height="280">
                        <TextBlock Text="Тут буде зображення ландшафту" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Опис епохи" Foreground="Gray" FontSize="12" Margin="0,20,0,5" TextAlignment="Left" FontWeight="Bold"/>
                    <TextBlock Text="Тут буде твій великий текст з опису предметної області..." 
                   Foreground="#DCDCDC" FontSize="15" TextWrapping="Wrap" LineHeight="22"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="ПРЕДСТАВНИКИ ЕПОХИ" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>

                    <UniformGrid Grid.Row="1" Columns="2">
                        <Border Background="#333" Margin="5" CornerRadius="8">
                            <TextBlock Text="Динозавр 1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="#333" Margin="5" CornerRadius="8">
                            <TextBlock Text="Динозавр 2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="#333" Margin="5" CornerRadius="8">
                            <TextBlock Text="Динозавр 3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="#333" Margin="5" CornerRadius="8">
                            <TextBlock Text="Динозавр 4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </UniformGrid>
                </Grid>
        </Border>
    </Grid>
    <Border Grid.Row="2" Background="#131313" BorderBrush="#333" BorderThickness="0,2,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Тріасовий" Width="120" Height="80" Margin="10" Background="#E67E22" Foreground="White" FontWeight="Bold"/>
            <Button Content="Юрський" Width="120" Height="80" Margin="10" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderBrush="White" BorderThickness="2"/>
            <Button Content="Крейдовий" Width="120" Height="80" Margin="10" Background="#2980B9" Foreground="White" FontWeight="Bold"/>
            <Button Content="Палеоген" Width="120" Height="80" Margin="10" Background="#8E44AD" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Grid>
</Window>
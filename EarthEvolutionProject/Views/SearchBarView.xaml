<UserControl x:Class="EarthEvolutionProject.Views.SearchBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EarthEvolutionProject.Views"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="18" Height="18" VerticalAlignment="Center">
                                    <Border x:Name="Box" Background="#1a4a82" BorderBrush="#2a5a92" BorderThickness="1.5" CornerRadius="5"/>
                                    <Path x:Name="CheckMark" Data="M 3,8 L 7,12 L 14,4" Stroke="White" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#3a7bc8"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1a4a82"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a5a92"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid Background="Transparent" Cursor="Hand" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                            <Border x:Name="BackgroundBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="18"/>

                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="ContentSite" 
                                          IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Text="▼" 
                                   Foreground="#88FFFFFF" 
                                   FontSize="10" 
                                   VerticalAlignment="Center" 
                                   Margin="5,0,0,0"/>
                            </Grid>

                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" PopupAnimation="Slide" StaysOpen="False">
                                <Border Background="White" BorderBrush="#2a5a92" BorderThickness="1" CornerRadius="8" Margin="0,5,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Button Content="Скинути все" 
                                            Background="Transparent" 
                                            Cursor="Hand"
                                            Click="ResetFilters_Click"
                                            Margin="0"
                                            HorizontalAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" 
                                                        Background="Transparent" 
                                                        BorderBrush="#EEE" 
                                                        BorderThickness="0,0,0,1" 
                                                        CornerRadius="8,8,0,0" 
                                                        Padding="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <ContentPresenter.Resources>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#d9534f"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </Style>
                                                            </ContentPresenter.Resources>
                                                        </ContentPresenter>
                                                    </Border>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#FFF0F0"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#FFE0E0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <ScrollViewer Grid.Row="1" Margin="4" MaxHeight="200">
                                            <StackPanel IsItemsHost="True" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    

    <StackPanel Orientation="Horizontal">
        <Button x:Name="BackButton" 
            Width="35" Height="35" 
            Margin="0,0,10,0"
            Cursor="Hand"
            Visibility="Collapsed"
            Click="BackButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BackBorder" 
                        Background="#1a4a82" 
                        CornerRadius="17.5" 
                        BorderBrush="#2a5a92" 
                        BorderThickness="1">
                        <TextBlock Text="←" 
                               Foreground="White" 
                               FontSize="18" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Margin="0,0,2,2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BackBorder" Property="Background" Value="#2a5a92"/>
                            <Setter TargetName="BackBorder" Property="BorderBrush" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        
        <Grid Width="250" Height="35" Margin="0,0,10,0">
            <Border Background="#1a4a82" CornerRadius="18" BorderBrush="#2a5a92" BorderThickness="1">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Foreground="#88FFFFFF" FontSize="12" Margin="0,0,8,0"/>
                    <TextBlock x:Name="PlaceholderText" Text="Пошук істот..." Foreground="#88FFFFFF" VerticalAlignment="Center" Grid.Column="1" IsHitTestVisible="False"/>
                    <TextBox x:Name="SearchInput" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" CaretBrush="White" TextChanged="SearchInput_TextChanged"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Width="150" Height="35">
            <TextBlock x:Name="ComboPlaceholder" Text="Всі категорії" Foreground="#88FFFFFF" VerticalAlignment="Center" Margin="15,0" IsHitTestVisible="False" Panel.ZIndex="1"/>
            <ComboBox x:Name="TypeFilter" Style="{StaticResource ComboBoxStyle}">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding TypeName}" 
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Click="OnFilterCheckBoxClick"
                                  Style="{StaticResource CheckBoxStyle}"
                                  Foreground="#1a4a82" Padding="5"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>
    </StackPanel>
</UserControl>